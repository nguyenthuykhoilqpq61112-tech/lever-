.prompt {
  box-sizing: border-box;
  width: 100%;
  min-height: 420rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #d0d5dd;
  border-radius: 16rpx;
  background: #f8fafc;
  color: #344054;
  font-size: 24rpx;
  line-height: 1.6;
}

.missing {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #fff7ed;
  color: #c2410c;
  font-size: 26rpx;
  line-height: 1.5;
}

.result {
  white-space: pre-wrap;
  color: #344054;
  font-size: 28rpx;
  line-height: 1.7;
}
