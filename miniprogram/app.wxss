page {
  min-height: 100%;
  color: #101828;
  background: #f6f8fb;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.container {
  padding: 32rpx;
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(16, 24, 40, 0.06);
}

.h1 {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.25;
}

.h2 {
  margin-bottom: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.p, .li {
  color: #475467;
  font-size: 28rpx;
  line-height: 1.7;
}

.badge {
  display: inline-flex;
  margin-bottom: 16rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #175cd3;
  background: #eff8ff;
  font-size: 24rpx;
}

.primary-button {
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: #13294b;
  color: #ffffff;
}

.secondary-button {
  margin-top: 16rpx;
  border-radius: 999rpx;
  color: #13294b;
  background: #eaf0f8;
}
